# NAS AI stack — /volume1/docker/ai/.env
# Copy to .env and fill in values. Never commit .env.

# LightRAG API key — shared by lightrag, vault-indexer, and lightrag-mcp.
# Generate: openssl rand -hex 32
LIGHTRAG_API_KEY=REPLACE_ME

# Tailscale auth key (one-time, for initial container auth).
# Generate at https://login.tailscale.com/admin/settings/keys
# Leave blank after first auth — Tailscale persists state in /var/lib/tailscale.
TS_AUTHKEY=
