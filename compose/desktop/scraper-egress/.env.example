# ProtonVPN gluetun config for the scraper egress isolation harness.
# Live secrets go in a SIBLING `.env` (git-ignored, chmod 600, desktop-only) — NEVER here.
# Non-secret fail-closed defaults below are committed as real values on purpose:
# flipping them must be a reviewable diff, not something filled in blind.
VPN_SERVICE_PROVIDER=
VPN_TYPE=
OPENVPN_USER=
OPENVPN_PASSWORD=
OPENVPN_PROTOCOL=
SERVER_COUNTRIES=
FIREWALL=on
# FIREWALL_OUTBOUND_SUBNETS: narrowed to the MINIMUM the scraper needs — a single DNS
# resolver /32, or leave EMPTY if the tunnel serves DNS. NEVER the full 10.0.0.0/24 LAN
# (the finpipe Postgres at 10.0.0.250, the NAS, and the desktop itself live on that /24).
FIREWALL_OUTBOUND_SUBNETS=
DNS_KEEP_NAMESERVER=off
DNS_ADDRESS=
DNS_SERVER=
VPN_PORT_FORWARDING=off
# HEALTH_TARGET_ADDRESS: gluetun pings this to gate its healthcheck on a real tunnel.
HEALTH_TARGET_ADDRESS=
PUID=
PGID=
TZ=America/New_York
# FIREWALL_ENABLED_DISABLING_IT_SHOOTS_YOU_IN_YOUR_FOOT: leave UNSET. Its own name is
# gluetun's warning — setting it disables the kill-switch this whole harness exists for.
