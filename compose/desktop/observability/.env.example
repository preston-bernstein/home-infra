# Shared observability stack — environment config.
# Real values are seeded on the desktop by deploy.sh; this file only documents
# what must be set and never carries real secrets (CONVENTIONS.md #5, .env is
# git-ignored — only this .env.example is tracked).

# Grafana admin password — left empty here; deploy.sh generates a random
# 32-character value and writes it into the desktop's real .env.
GRAFANA_ADMIN_PASSWORD=

# Host port Grafana is published on (distinct from fashion-monitor's :3001 and
# financial-pipeline's :3200).
GRAFANA_PORT=3300

# UID/GID of the `observability` service user — overwritten by deploy.sh with
# the real captured `id -u`/`id -g` values. Do not hand-edit.
PUID=
PGID=

# Timezone for container clocks/log timestamps.
TZ=America/New_York

# Host root directory for bind-mounted Prometheus/Grafana/Loki/Alloy data.
# Created by deploy.sh at deploy time.
DATA_ROOT=/opt/docker/observability
