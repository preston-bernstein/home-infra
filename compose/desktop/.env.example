# Desktop AI stack — /opt/docker/librechat-stack/.env
# Copy to .env and fill in values. Never commit .env.

# LibreChat
MONGO_URI=mongodb://localhost:27017/LibreChat
HOST=0.0.0.0
PORT=3080
ALLOW_REGISTRATION=true

# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME
JWT_REFRESH_SECRET=REPLACE_ME

# Ollama — routed through ollama-resource-broker (interactive port)
OLLAMA_BASE_URL=http://localhost:11435

# Proton Bridge MCP — bridge app password (NOT your Proton account password).
# Get from: docker exec protonmail-bridge /bin/sh -c '/root/.local/.../bridge --cli' → info
PROTON_USERNAME=your@protonmail.com
PROTON_PASSWORD=REPLACE_ME

# Anthropic — set when ready (keep $0 hard cap on Console until deliberate)
# ANTHROPIC_API_KEY=sk-ant-...
