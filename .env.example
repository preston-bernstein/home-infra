# media-ip-migrate.sh env — copy to .env, fill in values, never commit.

# Source IPs from old AT&T LAN (before USG migration)
OLD_NAS=OLD_NAS_IP
OLD_DESKTOP=OLD_DESKTOP_IP

# *arr API keys — find in each app under Settings → General → API Key
SONARR_KEY=REPLACE_ME
SONARR4K_KEY=REPLACE_ME
RADARR_KEY=REPLACE_ME
LIDARR_KEY=REPLACE_ME
READARR_KEY=REPLACE_ME
PROWLARR_KEY=REPLACE_ME
OVERSEERR_KEY=REPLACE_ME
